{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Quiz",
  "type": "object",
  "required": [
    "quizId",
    "title",
    "moduleId",
    "questions"
  ],
  "properties": {
    "quizId": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "moduleId": {
      "type": "string"
    },
    "duration": {
      "type": "string"
    },
    "passingScore": {
      "type": "number"
    },
    "questions": {
      "type": "array"
    }
  }
}
