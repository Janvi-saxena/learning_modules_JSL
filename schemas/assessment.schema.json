{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Assessment",
  "type": "object",
  "required": [
    "assessmentId",
    "title",
    "category",
    "questions"
  ],
  "properties": {
    "assessmentId": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "duration": {
      "type": "string"
    },
    "passingScore": {
      "type": "number"
    },
    "questions": {
      "type": "array"
    }
  }
}
