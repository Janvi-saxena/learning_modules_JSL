  "introduction": {
    "title": "What is MRP?",
    "content": "Material Requirements Planning (MRP) is one of the most important functions in SAP Production Planning. It determines which materials are required, in what quantity and at what time so that production can continue without interruption. MRP analyzes current inventory, open purchase orders, production orders, planned requirements and demand to generate procurement proposals."
  },

  "business_purpose": {
    "title": "Why is MRP Important?",
    "content": "MRP ensures that raw materials are available before production begins while preventing excess inventory. It helps organizations optimize inventory levels, improve production efficiency and reduce material shortages."
  },

  "mrp_objectives": [
    "Ensure material availability.",
    "Reduce inventory carrying costs.",
    "Plan procurement efficiently.",
    "Support uninterrupted production.",
    "Generate procurement proposals automatically."
  ],

