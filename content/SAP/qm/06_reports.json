  "introduction": {
    "title": "What are Quality Reports?",
    "content": "Quality Reports provide detailed information about inspection lots, inspection results, Usage Decisions, defects and quality performance. These reports help quality engineers, production teams and management monitor product quality, identify recurring issues and support continuous improvement."
  },

  "business_purpose": {
    "title": "Why are Quality Reports Important?",
    "content": "Quality reports provide visibility into inspection activities, defect trends and material quality. They help organizations identify quality problems early, improve manufacturing processes and ensure only quality products reach customers."
  },

  "standard_reports": [
    {
      "transaction_code": "QA32",
      "report_name": "Inspection Lot Processing",
      "purpose": "Monitor and process inspection lots."
    },
    {
      "transaction_code": "QA33",
      "report_name": "Display Inspection Lot",
      "purpose": "View completed inspection lots."
    },
    {
      "transaction_code": "QE51N",
      "report_name": "Result Recording",
      "purpose": "Display and record inspection results."
    },
    {
      "transaction_code": "QA11",
      "report_name": "Usage Decision",
      "purpose": "Display Usage Decision details."
    },
    {
      "transaction_code": "QP03",
      "report_name": "Display Inspection Plan",
      "purpose": "Review Inspection Plans."
    },
    {
      "transaction_code": "QS23",
      "report_name": "Display Master Inspection Characteristics",
      "purpose": "View inspection characteristics."
    }
  ],

