  "maintenance_types": [
    {
      "type": "Preventive Maintenance",
      "description": "Scheduled maintenance performed before failures occur."
    },
    {
      "type": "Corrective Maintenance",
      "description": "Repairs performed after equipment failure."
    },
    {
      "type": "Predictive Maintenance",
      "description": "Maintenance based on equipment condition and monitoring data."
    },
    {
      "type": "Breakdown Maintenance",
      "description": "Emergency maintenance carried out after unexpected machine breakdown."
    }
  ],

