  "business_example": {
    "title": "Example",
    "content": "A rolling mill motor develops excessive vibration. A maintenance notification is created in SAP, converted into a maintenance order, technicians perform repairs, spare parts are issued from inventory, testing is completed, and the maintenance history is updated for future reference."
  },

