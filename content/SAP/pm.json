  "learning_objectives": [
    "Understand the purpose of SAP Plant Maintenance.",
    "Learn the maintenance lifecycle in SAP.",
    "Understand equipment and functional locations.",
    "Learn preventive and corrective maintenance.",
    "Identify commonly used PM transaction codes."
  ],

  "introduction": {
    "title": "What is SAP PM?",
    "content": "SAP Plant Maintenance (PM) is used to manage, monitor and maintain equipment, machines and technical systems throughout their lifecycle. It helps organizations reduce equipment failures, improve asset reliability and optimize maintenance costs."
  },

  "business_purpose": {
    "title": "Why is SAP PM Used?",
    "content": "Manufacturing plants depend on machines operating efficiently. SAP PM helps schedule preventive maintenance, record breakdowns, manage repair activities and maintain equipment history, reducing downtime and increasing productivity."
  },

  "key_functions": [
    "Equipment Management",
    "Functional Location Management",
    "Preventive Maintenance",
    "Corrective Maintenance",
    "Maintenance Notifications",
    "Maintenance Orders",
    "Work Scheduling",
    "Maintenance History",
    "Spare Parts Management"
  ],

  "master_data": [
